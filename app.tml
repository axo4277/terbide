<win>
<head>
<title>TerbiumAI IDE</title>

<!-- Load CodeMirror Core & Themes -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/dracula.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>

<!-- Load All Language Modes -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/python/python.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/markdown/markdown.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/clike/clike.min.js"></script> <!-- For C, C++, Java -->

<!-- Load Addons -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/edit/closebrackets.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/edit/matchbrackets.min.js"></script>

<!-- Internal IDE Styles -->
<style>
* { box-sizing: border-box; }
body { margin: 0; padding: 0; background-color: #1e1e2e; color: #cdd6f4; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; height: 100vh; display: flex; flex-direction: column; }

/* Native Title Bar */
app-region { display: flex; align-items: center; background-color: #181825; padding: 6px 12px; border-bottom: 1px solid #313244; flex-shrink: 0; }
.app-title { font-weight: bold; color: #cba6f7; margin-right: 20px; font-size: 13px; }

/* Toolbar (File operations & Groq) */
#toolbar { display: flex; gap: 8px; align-items: center; flex-grow: 1; }
.tb-btn { background: #313244; color: #cdd6f4; border: 1px solid #45475a; padding: 3px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; }
.tb-btn:hover { background: #45475a; }
#groq-input { background: #11111b; border: 1px solid #45475a; color: #cdd6f4; padding: 3px 8px; border-radius: 4px; width: 180px; font-size: 12px; outline: none; }

/* Main IDE Container */
#ide-container { display: flex; flex-grow: 1; overflow: hidden; }
#editor-pane, #ai-pane { display: flex; flex-direction: column; width: 50%; }
#ai-pane { border-left: 1px solid #313244; }
.pane-header { background-color: #181825; padding: 6px 12px; font-size: 12px; color: #a6adc8; border-bottom: 1px solid #313244; display: flex; justify-content: space-between; }

/* Editor Fixes */
.CodeMirror { height: 100% !important; font-size: 14px; }

/* AI Chat Area */
#ai-chat-output { flex-grow: 1; padding: 15px; overflow-y: auto; font-family: monospace; font-size: 13px; white-space: pre-wrap; background: #11111b; }
#ai-input-area { display: flex; flex-direction: column; padding: 10px; background: #181825; border-top: 1px solid #313244; }
#ai-prompt { background: #1e1e2e; color: #cdd6f4; border: 1px solid #313244; border-radius: 4px; padding: 10px; resize: none; height: 60px; outline: none; margin-bottom: 10px; }
.ai-actions { display: flex; gap: 10px; justify-content: flex-end; }
.ai-btn { color: #1e1e2e; border: none; padding: 6px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; }
#ask-btn { background: #89b4fa; } #insert-btn { background: #a6e3a1; }

/* Hidden File Input */
#file-input { display: none; }
</style>
</head>

<!-- Window Title Bar & Toolbar -->
<app-region controls="overlay">
<span class="app-title">⟨/⟩ TerbiumIDE</span>
<div id="toolbar">
<button class="tb-btn" id="btn-new">New</button>
<button class="tb-btn" id="btn-open">Open</button>
<button class="tb-btn" id="btn-save">Save</button>
<button class="tb-btn" id="btn-saveas">Save As</button>
<input type="password" id="groq-input" placeholder="Groq API Key..." />
<button class="tb-btn" id="btn-groq-save" style="background:#fab387; color:#1e1e2e;">Save Key</button>
</div>
</app-region>

<body>
<input type="file" id="file-input" accept=".js,.mjs,.html,.htm,.css,.json,.py,.java,.c,.cpp,.md,.txt,.tml">

<div id="ide-container">
<!-- Code Editor -->
<div id="editor-pane">
<div class="pane-header">
<span id="file-name-display">Untitled</span>
<span id="lang-display">javascript</span>
</div>
<textarea id="code-editor">// Welcome to TerbiumIDE!
// Use the top bar to Open, Save, or create New files.
// Supports: JS, HTML, CSS, Python, JSON, C++, Java, and more.</textarea>
</div>

<!-- AI Assistant -->
<div id="ai-pane">
<div class="pane-header">
<span>Groq AI Assistant</span>
</div>
<div id="ai-chat-output">Paste your Groq API key in the top bar to enable AI.</div>
<div id="ai-input-area">
<textarea id="ai-prompt" placeholder="Ask AI to write code, explain errors, or refactor..."></textarea>
<div class="ai-actions">
<button class="ai-btn" id="ask-btn">Ask AI</button>
<button class="ai-btn" id="insert-btn">Insert Code</button>
</div>
</div>
</div>
</div>
</body>

<!-- Application Logic -->
<script>
let editor;
let lastAiCodeResponse = "";
let currentFileName = "Untitled";
let currentLanguage = "javascript";

// Used for the modern File System Access API (Save overwriting)
let fileHandle = null;

window.onload = () => {
editor = CodeMirror.fromTextArea(document.getElementById("code-editor"), {
mode: "javascript",
theme: "dracula",
lineNumbers: true,
autoCloseBrackets: true,
matchBrackets: true,
indentUnit: 4,
tabSize: 4
});

// Load saved Groq key
const savedKey = localStorage.getItem("terbium_groq_key");
if (savedKey) document.getElementById("groq-input").value = savedKey;

// Toolbar Listeners
document.getElementById("btn-new").addEventListener("click", createNewFile);
document.getElementById("btn-open").addEventListener("click", () => document.getElementById("file-input').click());
document.getElementById("btn-save").addEventListener("click", saveFile);
document.getElementById("btn-saveas").addEventListener("click", saveAsFile);
document.getElementById("btn-groq-save').addEventListener("click", saveGroqKey);

// File Input Listener (When user selects a file from the OS popup)
document.getElementById('file-input').addEventListener('change', handleFileOpen, false);

// AI Listeners
document.getElementById("ask-btn").addEventListener("click", askGroqAI);
document.getElementById("insert-btn").addEventListener("click", insertAiCode);

// Sync CodeMirror changes to our memory
editor.on('change', () => {
if(!currentFileName.includes('*')) {
currentFileName += ' *';
updateUI();
}
});
};

// --- FILE MANAGEMENT ---

function createNewFile() {
fileHandle = null;
currentFileName = "Untitled";
currentLanguage = "javascript";
editor.setValue("");
editor.setOption("mode", "javascript");
updateUI();
}

function handleFileOpen(event) {
const file = event.target.files[0];
if (!file) return;

const reader = new FileReader();
reader.onload = function(e) {
editor.setValue(e.target.result);
currentFileName = file.name;
setLanguageByExtension(file.name);
updateUI();
};
reader.readAsText(file);

// Reset input so the same file can be opened again if needed
document.getElementById('file-input').value = '';
}

async function saveFile() {
// If we have a file handle (from opening or saving previously), overwrite it
if (fileHandle) {
try {
const writable = await fileHandle.createWritable();
await writable.write(editor.getValue());
await writable.close();
currentFileName = currentFileName.replace(' *', ''); // Remove unsaved indicator
updateUI();
} catch (err) {
console.error("Save failed, falling back to Save As", err);
saveAsFile();
}
} else {
// No handle? Trigger Save As
saveAsFile();
}
}

async function saveAsFile() {
// Try to use the modern File System Access API
if (window.showSaveFilePicker) {
try {
fileHandle = await window.showSaveFilePicker({
suggestedName: currentFileName.replace(' *', ''),
types: [{
description: 'Code Files',
accept: { 'text/plain': ['.js', '.html', '.css', '.py', '.json', '.tml', '.txt'] }
}]
});
const writable = await fileHandle.createWritable();
await writable.write(editor.getValue());
await writable.close();
currentFileName = fileHandle.name;
setLanguageByExtension(currentFileName);
updateUI();
} catch (err) {
if (err.name !== 'AbortError') console.error(err); // User cancelled
}
} else {
// Fallback for older browsers/iframes (Standard Download)
const blob = new Blob([editor.getValue()], { type: 'text/plain' });
const a = document.createElement('a');
a.href = URL.createObjectURL(blob);
a.download = currentFileName.replace(' *', '');
document.body.appendChild(a);
a.click();
document.body.removeChild(a);
URL.revokeObjectURL(a.href);
}
}

// --- LANGUAGE DETECTION ---

function setLanguageByExtension(filename) {
const ext = filename.split('.').pop().toLowerCase();
const modeMap = {
'js': 'javascript', 'mjs': 'javascript',
'html': 'htmlmixed', 'htm': 'htmlmixed', 'tml': 'htmlmixed',
'css': 'css',
'json': { name: 'javascript', json: true },
'py': 'python',
'java': 'text/x-java',
'c': 'text/x-csrc', 'cpp': 'text/x-c++src', 'cc': 'text/x-c++src',
'md': 'markdown',
'xml': 'xml', 'svg': 'xml'
};

currentLanguage = modeMap[ext] || 'text/plain';
editor.setOption("mode", currentLanguage);
}

function updateUI() {
document.getElementById("file-name-display").innerText = currentFileName;
document.getElementById("lang-display").innerText = typeof currentLanguage === 'string' ? currentLanguage : currentLanguage.name;
}

// --- GROQ AI LOGIC ---

function saveGroqKey() {
const key = document.getElementById("groq-input").value.trim();
if (key) {
localStorage.setItem("terbium_groq_key", key);
document.getElementById("ai-chat-output").innerText = "✅ Groq API Key saved securely!";
}
}

async function askGroqAI() {
const apiKey = localStorage.getItem("terbium_groq_key");
const prompt = document.getElementById("ai-prompt").value.trim();
const currentCode = editor.getValue();
const outputDiv = document.getElementById("ai-chat-output");

if (!apiKey) return outputDiv.innerText = "❌ Please save your Groq API key in the top bar.";
if (!prompt) return outputDiv.innerText = "❌ Please enter a prompt.";

outputDiv.innerText = "⏳ Thinking...\n\n";
document.getElementById("ask-btn").disabled = true;

try {
const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
method: "POST",
headers: { "Authorization": `Bearer ${apiKey}`, "Content-Type": "application/json" },
body: JSON.stringify({
model: "llama-3.3-70b-versatile",
messages: [
{ role: "system", content: `You are an AI coding assistant inside TerbiumIDE. The user is editing a file named '${currentFileName}' using the language mode '${currentLanguage}'.\n\nCurrent Code:\n${currentCode}\n\nAnswer their question. If generating code, output ONLY the raw code without markdown formatting (no \`\`\` tags) so it can be injected directly into the editor.` },
{ role: "user", content: prompt }
],
temperature: 0.2,
max_tokens: 1500
})
});

const data = await response.json();
if (data.error) {
outputDiv.innerText = "❌ API Error: " + data.error.message;
} else {
lastAiCodeResponse = data.choices[0].message.content;
outputDiv.innerText = lastAiCodeResponse;
}
} catch (err) {
outputDiv.innerText = "❌ Network Error.";
} finally {
document.getElementById("ask-btn").disabled = false;
}
}

function insertAiCode() {
if (lastAiCodeResponse) {
editor.setValue(lastAiCodeResponse);
} else {
alert("Ask the AI to generate code first!");
}
}
</script>
</win>